{
  "expo": {
    "name": "Colophon",
    "slug": "colophon",
    "owner": "whalesrecords",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "colophon",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.whalesrecords.colophon",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.whalesrecords.colophon",
      "adaptiveIcon": {
        "backgroundColor": "#F4EEE2",
        "foregroundImage": "./assets/images/icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Colophon utilise la caméra pour scanner les codes-barres (ISBN) de vos livres."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Colophon accède à vos photos pour choisir un avatar ou une couverture de livre.",
          "cameraPermission": "Colophon utilise l'appareil photo pour vos avatars et couvertures."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F4EEE2",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1ad6d36-5f54-4d37-8e49-08dee76d0efc"
      }
    }
  }
}
