{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "expo", "start", "--web", "--port", "8090"],
      "port": 8090,
      "autoPort": false
    },
    {
      "name": "web-static",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8091", "--directory", "dist"],
      "port": 8091,
      "autoPort": false
    }
  ]
}
